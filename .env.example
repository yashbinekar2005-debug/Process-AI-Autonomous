# LLM Provider: "ollama" (default) or "gemini"
LLM_PROVIDER=ollama

# Ollama (local, free) - https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Gemini API Key (fallback / secondary provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Tavily Search API Key (optional - falls back to DuckDuckGo free search)
TAVILY_API_KEY=

# Redis connection string for persistence
REDIS_URL=redis://localhost:6379

# Local Vector DB Path
CHROMA_DB_PATH=./chroma_db

# Web API Settings
PORT=8000
HOST=0.0.0.0

# LLM Retry Configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2.0

# Action Agent Credentials (Optional)
SLACK_WEBHOOK_URL=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=admin@enterprise.com
