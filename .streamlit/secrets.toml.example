# STREAMLIT SECRETS - DEPLOYMENT ONLY
# This file is for Streamlit Cloud deployment secrets
# DO NOT commit this to Git - it contains sensitive data

# Your API Keys (get from your accounts)
GEMINI_API_KEY = "your_gemini_api_key_here"
TAVILY_API_KEY = "your_tavily_api_key_here"

# Backend API URL (update after deploying FastAPI)
# For local testing: http://localhost:8000/api/tasks
# For cloud: https://your-backend-url.onrender.com/api/tasks
BACKEND_URL = "http://localhost:8001"
REDIS_URL = "redis://localhost:6379"
